#!/usr/bin/executor

#требуется lib/IConfiguration.sbsl
#требуется lib/IProjectProperties.sbsl
#требуется lib/IProject.sbsl
#требуется lib/IIBOperation.sbsl
#требуется lib/oc_main.sbsl

метод Скрипт(Режим = "", ПутьДоРепозитория = "", Пауза = 0, ПутьКНастройкам = "", ИменаИБ: Массив<Строка>? = Неопределено)

    пер СтатусВыполнения = Ложь

    если ПутьДоРепозитория.Пусто()
        если Пауза > 0
            Консоль.СчитатьСтроку("Не задан путь до репозитория. Нажмите Enter...")
        ;
        выбросить новый ИсключениеНедопустимоеСостояние()
    ;

    ПутьДоРепозитория = oc_main.ИсправитьРазделителиПути(ПутьДоРепозитория)
    ПутьКНастройкам   = oc_main.ИсправитьРазделителиПути(ПутьКНастройкам)
    знч РабочийКаталог    = Скрипт.ПолучитьРабочийКаталог()

    если oc_main.ЭтоАбсолютныйПуть(ПутьДоРепозитория)
        Скрипт.УстановитьРабочийКаталог(ПутьДоРепозитория)
    иначе
        Скрипт.УстановитьРабочийКаталог(oc_main.ДобавитьЧастьПути(РабочийКаталог, [ПутьДоРепозитория]))
    ;

    пер ПараметрыПроекта: IProjectProperties.ПараметрыПроекта?

    попытка

        ПараметрыПроекта = IProjectProperties.ПараметрыПроекта.Инициализировать(
            ПутьКНастройкам,
            ИменаИБ ?? новый Массив<Строка>(),
            Режим.Содержит("_ib_") или Режим.ЗаканчиваетсяНа("_ib"))

        выбор Режим.ВНижнийРегистр()
        когда "init"
            ИнициализироватьСкриптыВыполнения(ПараметрыПроекта, ПутьДоРепозитория, ПутьКНастройкам)
            ИнициализироватьGitPrecommit(ПараметрыПроекта, ПутьКНастройкам)
            СтатусВыполнения = Истина
        когда "check_bin"
            СтатусВыполнения = IProject.АнализироватьНастройкиПоддержки(ПараметрыПроекта)
        когда "repair_bin"
            СтатусВыполнения = IProject.АнализироватьНастройкиПоддержки(ПараметрыПроекта, Истина)
        когда "check_bin_prod"
            СтатусВыполнения = IProject.АнализироватьНастройкиПоддержкиКонфигурацииПоставщика(ПараметрыПроекта)
        когда "repair_bin_prod"
            СтатусВыполнения = IProject.АнализироватьНастройкиПоддержкиКонфигурацииПоставщика(ПараметрыПроекта, Истина)
        когда "new_bin"
            знч ОсновнаяКонфигурация = ПараметрыПроекта.ПолучитьОсновнуюКонфигурацию()
            IProject.ПеревестиФайлИзмененныхОбъектовВНовыйФормат(ОсновнаяКонфигурация.ПутьКФайламКонфигурации.ФайлыПроекта)
            СтатусВыполнения = Истина
        когда "new_configdumpinfo"
            знч ОсновнаяКонфигурация = ПараметрыПроекта.ПолучитьОсновнуюКонфигурацию()
            IProject.ПеревестиФайлИсторииОбъектовВНовыйФормат(ОсновнаяКонфигурация.ПутьКФайламКонфигурации.ФайлыПроекта)
            СтатусВыполнения = Истина
            для Расширение из ПараметрыПроекта.ПолучитьРасширения()
                IProject.ПеревестиФайлИсторииОбъектовВНовыйФормат(Расширение.ПутьКФайламКонфигурации.ФайлыПроекта)
            ;
        когда "check_ib_cf"
            СтатусВыполнения = IProject.ВыполнитьПроверкуКонфигурации(ПараметрыПроекта)
        когда "check_ib_cfe"
            СтатусВыполнения = IProject.ВыполнитьПроверкуКонфигурации(ПараметрыПроекта, Истина)
        когда "check_ib"
            СтатусВыполнения = IProject.ВыполнитьТестированиеИсправление(ПараметрыПроекта)
        когда "get_ib_configdumpinfo"
            знч ИнформационнаяБаза = ПараметрыПроекта.ПолучитьОсновнуюИнформационнуюБазу()
            СтатусВыполнения = IProject.ПолучитьФайлыКонфигурации(ПараметрыПроекта, ИнформационнаяБаза, "ConfigDumpInfo.xml")
        когда "get_prod_configdumpinfo"
            СтатусВыполнения = IProject.ПолучитьФайлыКонфигурацииПоставщика(ПараметрыПроекта, "ConfigDumpInfo.xml")
        когда "get_ib_status"
            СтатусВыполнения = IProject.ПолучитьСтатусКонфигурации(ПараметрыПроекта)
        когда "get_ib_xml"
            знч ИнформационнаяБаза = ПараметрыПроекта.ПолучитьОсновнуюИнформационнуюБазу()
            СтатусВыполнения = IProject.ПолучитьФайлыКонфигурации(ПараметрыПроекта, ИнформационнаяБаза)
        когда "get_ib_cfe_xml"
            СтатусВыполнения = Истина
            для Расширение из ПараметрыПроекта.ПолучитьРасширения()
                знч ИнформационнаяБаза = ПараметрыПроекта.ПолучитьИнформационнуюБазуКонфигурации(Расширение)
                СтатусВыполнения = СтатусВыполнения и IProject.ПолучитьФайлыКонфигурации(ПараметрыПроекта, ИнформационнаяБаза)
            ;
        когда "get_prod_xml"
            СтатусВыполнения = IProject.ПолучитьФайлыКонфигурацииПоставщика(ПараметрыПроекта)
        когда "update_ib"
            СтатусВыполнения = IProject.ОбновитьИнформационнуюБазу(ПараметрыПроекта)
        когда "update_ib_cf"
            СтатусВыполнения = IProject.ОбновитьФайлыКонфигурации(ПараметрыПроекта, 1)
        когда "update_ib_cf_xml"
            СтатусВыполнения = IProject.ОбновитьФайлыКонфигурации(ПараметрыПроекта, 2)
        когда "update_ib_cfe"
            СтатусВыполнения = IProject.ОбновитьФайлыКонфигурации(ПараметрыПроекта, 3)
        когда "update_ib_cfe_xml"
            СтатусВыполнения = IProject.ОбновитьФайлыКонфигурации(ПараметрыПроекта, 4)
        когда "update_ib_patch"
            СтатусВыполнения = IProject.ОбновитьФайлыКонфигурации(ПараметрыПроекта, 5)
        когда "build_cf"
            СтатусВыполнения = IProject.СобратьФайлыКонфигурации(ПараметрыПроекта)
        когда "build_cfe"
            СтатусВыполнения = IProject.СобратьФайлыКонфигурации(ПараметрыПроекта, Истина)
        когда "build_patch"
            СтатусВыполнения = IProject.СобратьПатчКонфигурации(ПараметрыПроекта) != Неопределено
        когда "build_prod"
            СтатусВыполнения = IProject.СобратьФайлыКонфигурации(ПараметрыПроекта, Ложь, Истина)
        когда "git_sync_ib"
            СтатусВыполнения = IProject.СинхронизироватьХранилищеКонфигурацийСGitХранилищем(ПараметрыПроекта)
        когда "commit_ib_xml"
            СтатусВыполнения = IProject.ПоместитьИзмененияКонфигурацийВGitХранилище(ПараметрыПроекта)
        иначе
            Консоль.Записать(
                "Неизвестный режим запуска %Режим\н")
            если Пауза > 0
                Консоль.СчитатьСтроку("Нажмите Enter...")
            ;
            выбросить новый ИсключениеНедопустимоеСостояние()
        ;

    поймать Исключение: Исключение
        если не Исключение.Описание.Пусто()
            Консоль.Записать("\н#################################################################")
            Консоль.Записать(Исключение.Описание)
            Консоль.Записать("#################################################################")
        ;
    ;

    если не ПараметрыПроекта == Неопределено
        ПараметрыПроекта.ЗаписатьПользовательскиеНастройки()
    ;

    если СтатусВыполнения
        если Режим == "init" и Пауза > 0
            Консоль.СчитатьСтроку("\нИнициализация закончена. Нажмите Enter...")
        иначе если Пауза > 0
            Консоль.СчитатьСтроку("\нКонвертация закончена. Нажмите Enter...")
        иначе
            Консоль.Записать("\нКонвертация закончена")
        ;
    иначе
        если Пауза > 0
            Консоль.СчитатьСтроку("\нОшибка выполнения. Нажмите Enter...")
        иначе
            Консоль.Записать("\нОшибка выполнения")
        ;
        выбросить новый ИсключениеНедопустимоеСостояние()
    ;
;

метод ИнициализироватьСкриптыВыполнения(ПараметрыПроекта: IProjectProperties.ПараметрыПроекта, ПутьДоРепозитория: Строка, ПутьКНастройкам: Строка)

    знч используемаяОС = oc_main.ИспользуемаяОС()

    пер Расширение = ""
    пер Шебанг = ""
    выбор используемаяОС
    когда oc_main.ОперационныеСистемы.Windows
        Расширение = "bat"
    когда oc_main.ОперационныеСистемы.Linux
        Расширение = "sh"
        Шебанг = "#!/usr/bin/bash\н"
    ;

    знч КомандыЗапуска = [
        "check_ib_cf",
        "check_ib_cfe",
        "check_ib",
        "build_cf",
        "build_prod",
        "build_cfe",
        "build_patch",
        "get_ib_configdumpinfo",
        "get_ib_xml",
        "get_ib_cfe_xml",
        "get_ib_status",
        "update_ib_cf",
        "update_ib_cf_xml",
        "update_ib_cfe",
        "update_ib_cfe_xml",
        "update_ib_patch",
        "update_ib",
        "git_sync_ib",
        "commit_ib_xml"
    ]

    пер ПутьКСкриптуИсполненияПараметр = ПараметрыПроекта.Платформа.ПутьКСкриптуИсполнения.ОтносительныйПуть
    если не oc_main.ЭтоАбсолютныйПуть(ПутьКСкриптуИсполненияПараметр)
        ПутьКСкриптуИсполненияПараметр = oc_main.ДобавитьЧастьПути(ПутьДоРепозитория, [ПутьКСкриптуИсполненияПараметр])
    ;

    знч СР = Файлы.СимволРазделителя
    знч ПутьДоРепозиторияПараметр = "\"" + ((СР == "\\") ? ПутьДоРепозитория.Заменить(СР, "\\\\") : ПутьДоРепозитория) + "\""
    знч ПутьКНастройкамПараметр = ПутьКНастройкам.Пусто()
        ? ""
        : "\"" + ((СР == "\\") ? ПутьКНастройкам.Заменить(СР, "\\\\") : ПутьКНастройкам) + "\""

    для Команда из КомандыЗапуска
        
        выбор используемаяОС
        когда oc_main.ОперационныеСистемы.Windows
            Расширение = "bat"
            знч ФайлСкрипта = новый Файл(oc_main.ДобавитьЧастьПути(ПараметрыПроекта.КонтекстИсполнения.ПутьКСборкеПроекта.ФайлыПроекта.Путь, ["%{Команда}.%{Расширение}"]))
            ФайлСкрипта.ОткрытьПотокЗаписи(Ложь)
                .Записать("executor \"%{ПутьКСкриптуИсполненияПараметр}\" -Режим %{Команда} -ПутьДоРепозитория %{ПутьДоРепозиторияПараметр} -Пауза 1 %{ПутьКНастройкамПараметр .Пусто() ? "" : "-ПутьКНастройкам " + ПутьКНастройкамПараметр}", Кодировка.Cp866).Закрыть()
        когда oc_main.ОперационныеСистемы.Linux
            Расширение = "sh"
            Шебанг = "#!/usr/bin/bash\н"
            знч ФайлСкрипта = новый Файл(oc_main.ДобавитьЧастьПути(ПараметрыПроекта.КонтекстИсполнения.ПутьКСборкеПроекта.ФайлыПроекта.Путь, ["%{Команда}.%{Расширение}"]))
            ФайлСкрипта.ОткрытьПотокЗаписи(Ложь)
                .Записать(Шебанг)
                .Записать("executor \"%{ПутьКСкриптуИсполненияПараметр}\" -Режим \"%{Команда}\" -ПутьДоРепозитория \"%{ПутьДоРепозиторияПараметр}\" -Пауза 1 %{ПутьКНастройкамПараметр .Пусто() ? "" : "-ПутьКНастройкам \"" + ПутьКНастройкамПараметр + "\""}").Закрыть()
        ;
    ;
;

метод ИнициализироватьGitPrecommit(ПараметрыПроекта: IProjectProperties.ПараметрыПроекта, ПутьКНастройкам: Строка)

    знч КаталогHooks = новый Файл(oc_main.ДобавитьЧастьПути(".git", ["hooks"]))
    если не КаталогHooks.Существует()
        Консоль.Записать("\н#################################################################")
        Консоль.Записать("Не найдены системные файлы git репозитория \"${КаталогHooks.Путь}\"")
        Консоль.Записать("#################################################################")
        возврат
    ;

    знч СР = Файлы.СимволРазделителя
    знч СРLinux = "/"

    знч ПутьКСкриптуИсполненияПараметр = "\"" + ПараметрыПроекта.Платформа.ПутьКСкриптуИсполнения.ОтносительныйПуть.Заменить(СР, СРLinux) + "\""
    знч ПутьКНастройкамПараметр = ПутьКНастройкам.Пусто()
        ? ""
        : "\"" + ПутьКНастройкам.Заменить(СР, СРLinux) + "\""

    знч ОсновнаяКонфигурация = ПараметрыПроекта.ПолучитьОсновнуюКонфигурацию()
    знч ФайлConfigDumpInfo = IConfiguration.ПолучитьФайлConfigDumpInfo(ОсновнаяКонфигурация.ПутьКФайламКонфигурации.ФайлыПроекта)
    знч ОтносительныйПутьConfigDumpInfo = oc_main.УдалитьЧастьПути(ФайлConfigDumpInfo.Путь, [ПараметрыПроекта.КонтекстИсполнения.РабочийКаталог]).Заменить(СР, СРLinux)
    знч ФайлParentConfigurations = IConfiguration.ПолучитьФайлParentConfigurations(ОсновнаяКонфигурация.ПутьКФайламКонфигурации.ФайлыПроекта)
    знч ОтносительныйПутьParentConfigurations = oc_main.УдалитьЧастьПути(ФайлParentConfigurations.Путь, [ПараметрыПроекта.КонтекстИсполнения.РабочийКаталог]).Заменить(СР, СРLinux)
    пер ОтносительныйПутьConfigDumpInfoРасширений = ""
    для Расширение из ПараметрыПроекта.ПолучитьРасширения()
        ОтносительныйПутьConfigDumpInfoРасширений = Расширение.ПутьКФайламКонфигурации.ОтносительныйПуть
        ОтносительныйПутьConfigDumpInfoРасширений = oc_main.ДобавитьЧастьПути(
             ОтносительныйПутьConfigDumpInfoРасширений.Заменить(Расширение.ПутьКФайламКонфигурации.Имя, "*"),
             [ФайлConfigDumpInfo.Имя]).Заменить(СР, СРLinux)
        прервать
    ;

    знч ТекстPrecommit =
        "#!/bin/sh
        executor %{ПутьКСкриптуИсполненияПараметр} -Режим \"new_bin\" -ПутьДоРепозитория \".\" -Пауза 0 -ПутьКНастройкам \"%{ПутьКНастройкамПараметр}\"
        executor %{ПутьКСкриптуИсполненияПараметр} -Режим \"new_configdumpinfo\" -ПутьДоРепозитория \".\" -Пауза 0 -ПутьКНастройкам \"%{ПутьКНастройкамПараметр}\"
        git add  %{ОтносительныйПутьParentConfigurations} %{ОтносительныйПутьConfigDumpInfo} %{ОтносительныйПутьConfigDumpInfoРасширений}
        executor %{ПутьКСкриптуИсполненияПараметр} -Режим \"build_cfe\" -ПутьДоРепозитория \".\" -Пауза 0  -ПутьКНастройкам \"%{ПутьКНастройкамПараметр}\""

    знч ФайлPrecommit = новый Файл(oc_main.ДобавитьЧастьПути(".git", ["hooks", "pre-commit"]))
    если ФайлPrecommit.Существует()
        Консоль.Записать("\н#################################################################")
        Консоль.Записать("Файл \"%{ФайлPrecommit.Путь}\" существует. Необходимо внести в него следующие строки:")
        Консоль.Записать("\н")
        Консоль.Записать(ТекстPrecommit)
        Консоль.Записать("\н")
        Консоль.Записать("#################################################################")
        возврат
    ;

    ФайлPrecommit.ОткрытьПотокЗаписи().Записать(ТекстPrecommit).Закрыть()
;
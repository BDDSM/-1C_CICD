#!/usr/bin/executor

@Глобально
структура ПараметрыGit

    пер Путь: Строка
    пер ОсновнаяВетка: Строка
    пер ЛокальныйПуть: Строка
    пер Логин: Строка
    пер Пароль: Строка
    пер Ключ: Строка


// ПрограммныйИнтерфейс

// ВнешнееХранилище

    @Глобально
    метод ПолучитьВнешнееХранилище()

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ПараметрыПроцесса.Добавить("clone")
        ДополнитьПараметрыПроцессаПутьКХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить(ЛокальныйПуть)
        знч ВременныйФайл = ДополнитьПараметрыПроцессаКлючом(ПараметрыПроцесса)

        ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)

        Файлы.Удалить(ВременныйФайл, Истина)

        Консоль.Записать("Хранилище Git получено")

    ;

    @Глобально
    метод ПолучитьИзмененияИзВнешнегоХранилища(ИмяВетки = ""): Булево

        если ИмяВетки.Пусто()
            ИмяВетки = ОсновнаяВетка
        ;

        если не ТекущаяВеткаХранилищаСопоставленаСВнешней(ИмяВетки)
            возврат Ложь
        ;

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить("pull")
        ПараметрыПроцесса.Добавить("origin")
        ПараметрыПроцесса.Добавить(ИмяВетки)
        ДополнитьПараметрыПроцессаПутьКХранилищу(ПараметрыПроцесса)
        знч ВременныйФайл = ДополнитьПараметрыПроцессаКлючом(ПараметрыПроцесса)

        ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)

        Файлы.Удалить(ВременныйФайл, Истина)

        Консоль.Записать("Получены изменения из хранилище Git")

        возврат Истина

    ;

    @Глобально
    метод ОтправитьИзмененияВоВнешнееХранилище(ИмяВетки = "")

        если ИмяВетки.Пусто()
            ИмяВетки = ОсновнаяВетка
        ;

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить("push")
        ПараметрыПроцесса.Добавить("--set-upstream")
        ПараметрыПроцесса.Добавить("origin")
        ПараметрыПроцесса.Добавить("%{ИмяВетки}:%{ИмяВетки}")
        ДополнитьПараметрыПроцессаПутьКХранилищу(ПараметрыПроцесса)
        знч ВременныйФайл = ДополнитьПараметрыПроцессаКлючом(ПараметрыПроцесса)

        ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)

        Файлы.Удалить(ВременныйФайл, Истина)

        Консоль.Записать("Отправлены изменения в хранилище Git")

    ;

    @Глобально
    метод ПроверитьСуществованиеВеткиВнешнегоХранилища(ИмяВетки = ""): Число

        пер Результат = 0

        если ИмяВетки.Пусто()
            ИмяВетки = ОсновнаяВетка
        ;

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить("branch")
        ПараметрыПроцесса.Добавить("-r")
        ПараметрыПроцесса.Добавить("--list")
        ПараметрыПроцесса.Добавить("origin/%{ИмяВетки}")
        ДополнитьПараметрыПроцессаПутьКХранилищу(ПараметрыПроцесса)
        знч ВременныйФайл = ДополнитьПараметрыПроцессаКлючом(ПараметрыПроцесса)

        знч РезультатКоманды = ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)

        если РезультатКоманды.Содержит("*")
            Результат = 2 // Искомая ветка - текущая
        иначе если РезультатКоманды.Сократить() == "origin/%{ИмяВетки}"
            Результат = 1 // Искомая ветка существует
        ;

        Файлы.Удалить(ВременныйФайл, Истина)

        возврат Результат

    ;

    @Глобально
    метод ПерейтиНаВеткуВнешнегоХранилища(ИмяВетки = "") : Булево

        если ИмяВетки.Пусто()
            ИмяВетки = ОсновнаяВетка
        ;

        пер СтатусВетки = ПроверитьСуществованиеВеткиВнешнегоХранилища(ИмяВетки)

        если СтатусВетки == 0
            возврат Ложь
        иначе если СтатусВетки == 2
            возврат Истина
        ;

        если ПерейтиНаВеткуХранилища(ИмяВетки)
            возврат ПолучитьИзмененияИзВнешнегоХранилища(ИмяВетки)
        ;

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить("checkout")
        ПараметрыПроцесса.Добавить("-b")
        ПараметрыПроцесса.Добавить(ИмяВетки)
        ПараметрыПроцесса.Добавить("origin/%{ИмяВетки}")
        ДополнитьПараметрыПроцессаПутьКХранилищу(ПараметрыПроцесса)
        знч ВременныйФайл = ДополнитьПараметрыПроцессаКлючом(ПараметрыПроцесса)

        ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)

        Файлы.Удалить(ВременныйФайл, Истина)

        возврат Истина

    ;

    @Глобально
    метод ПолучитьДанныеФайлаВнешнегоХранилища(ПутьКФайлу: Строка, ИмяВетки = "") : Строка

        если ИмяВетки.Пусто()
            ИмяВетки = ОсновнаяВетка
        ;

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить("show")
        ПараметрыПроцесса.Добавить("origin/%{ИмяВетки}:%{ПутьКФайлу}")
        ДополнитьПараметрыПроцессаПутьКХранилищу(ПараметрыПроцесса)
        знч ВременныйФайл = ДополнитьПараметрыПроцессаКлючом(ПараметрыПроцесса)

        знч ДанныеФайла = ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)

        Файлы.Удалить(ВременныйФайл, Истина)

        возврат ДанныеФайла
    ;

    // ЛокальноеХранилище

    @Глобально
    метод СоздатьВеткуХранилища(ИмяВетки = "", ВеткаРодитель = "")

        если ИмяВетки.Пусто()
            ИмяВетки = ОсновнаяВетка
        ;

        если ВеткаРодитель.Пусто()
            ВеткаРодитель = ОсновнаяВетка
        ;

        если ИмяВетки == ВеткаРодитель
            возврат
        ;

        если ПерейтиНаВеткуХранилища(ИмяВетки)
            возврат
        ;

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить("checkout")
        ПараметрыПроцесса.Добавить("-b")
        ПараметрыПроцесса.Добавить("%{ИмяВетки}")
        если не ВеткаРодитель.Пусто()
            ПараметрыПроцесса.Добавить("%{ВеткаРодитель}")
        ;

        ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)

        Консоль.Записать("Создана ветка %{ИмяВетки}")

    ;

    @Глобально
    метод ПолучитьИмяТекущейВеткиХранилища(): Строка

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить("branch")
        ПараметрыПроцесса.Добавить("--list")
    
        знч Ветки = ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)

        знч ОбразецПоискаВерсии = '\*.(?<ИмяВетки>.*)'
        знч РезультатПоискаВерсии = ОбразецПоискаВерсии.НайтиСовпадения(Ветки)
        пер ИмяВетки = ""
        для ОчереднойРезультат из РезультатПоискаВерсии
            ИмяВетки = ОчереднойРезультат.Группа("ИмяВетки")
        ;

        возврат ИмяВетки

    ;

    @Глобально
    метод ПолучитьИмяВнешнейВеткиХранилища(ИмяВетки = ""): Строка

        если ИмяВетки.Пусто()
            ИмяВетки = ОсновнаяВетка
        ;

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить("branch")
        ПараметрыПроцесса.Добавить("--list")
        ПараметрыПроцесса.Добавить("-vv")
        ПараметрыПроцесса.Добавить(ИмяВетки)
    
        знч Ветки = ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)

        знч ОбразецПоиска = '.*\[(?<ИмяВнешнейВетки>.*)\].*'
        знч РезультатПоиска = ОбразецПоиска.НайтиСовпадения(Ветки)
        пер ИмяВнешнейВетки = ""
        для ОчереднойРезультат из РезультатПоиска
            ИмяВнешнейВетки = ОчереднойРезультат.Группа("ИмяВнешнейВетки")
        ;

        возврат ИмяВнешнейВетки

    ;

    @Глобально
    метод ТекущаяВеткаХранилищаОсновная(): Булево

        знч ИмяВетки = ПолучитьИмяТекущейВеткиХранилища()

        возврат ИмяВетки == ОсновнаяВетка

    ;

    @Глобально
    метод ТекущаяВеткаХранилищаСопоставленаСВнешней(ИмяВетки = ""): Булево

        если ИмяВетки.Пусто()
            ИмяВетки = ОсновнаяВетка
        ;

        знч ИмяВнешнейВетки = ПолучитьИмяВнешнейВеткиХранилища(ИмяВетки)

        возврат не ИмяВнешнейВетки.Пусто()

    ;

    @Глобально
    метод ПерейтиНаВеткуХранилища(ИмяВетки = ""): Булево

        если ИмяВетки.Пусто()
            ИмяВетки = ОсновнаяВетка
        ;

        пер СтатусВетки = ПроверитьСуществованиеВеткиХранилища(ИмяВетки)

        если СтатусВетки == 0
            возврат Ложь
        иначе если СтатусВетки == 2
            возврат Истина
        ;

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить("checkout")
        ПараметрыПроцесса.Добавить(ИмяВетки)
    
        ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)

        возврат Истина

    ;

    @Глобально
    метод ПроверитьСуществованиеВеткиХранилища(ИмяВетки = ""): Число

        пер Результат = 0

        если ИмяВетки.Пусто()
            ИмяВетки = ОсновнаяВетка
        ;

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить("branch")
        ПараметрыПроцесса.Добавить("--list")
        ПараметрыПроцесса.Добавить("%{ИмяВетки}")

        знч РезультатКоманды = ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)
        если РезультатКоманды.Содержит("*")
            Результат = 2 // Искомая ветка - текущая
        иначе если РезультатКоманды.Сократить() == ИмяВетки
            Результат = 1 // Искомая ветка существует
        ;

        возврат Результат

    ;

    @Глобально
    метод ИмеютсяИзмененияВХранилище(): Булево

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить("diff")
        ПараметрыПроцесса.Добавить("--name-only")

        знч ИзмененияВКонфигурации = ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)

        возврат не ИзмененияВКонфигурации.Пусто()

    ;

    @Глобально
    метод ПроиндексироватьИзмененияВХранилище(Файлы = ".")

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить("add")
        ПараметрыПроцесса.Добавить(Файлы)

        ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)

    ;

    @Глобально
    метод ЗафиксироватьИзмененияВХранилище(КомментарийХранилища: Строка)

        ПроиндексироватьИзмененияВХранилище()

        знч ПараметрыПроцесса = новый Массив<Строка>()
        ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса)
        ПараметрыПроцесса.Добавить("commit")
        ПараметрыПроцесса.Добавить("-m")
        ПараметрыПроцесса.Добавить("\"%{КомментарийХранилища}\"")

        ВыполнитьКомандуСОжиданием("git", ПараметрыПроцесса)
    ;

    // СлужебныеПроцедурыИФункции

    @Локально
    метод ДополнитьПараметрыПроцессаПутьКХранилищу(ПараметрыПроцесса: Массив<Строка>)

        пер ПутьКХранилищуЛогинПароль = Путь

        если не Логин.Пусто() и не Пароль.Пусто()
            если ПутьКХранилищуЛогинПароль.НачинаетсяС("http://")
                ПутьКХранилищуЛогинПароль = "http://%{Логин}:%{Пароль}@%{Путь.Подстрока(8)}"
            иначе если ПутьКХранилищуЛогинПароль.НачинаетсяС("https://")
                ПутьКХранилищуЛогинПароль = "https://%{Логин}:%{Пароль}@%{Путь.Подстрока(9)}"
            ;
        ;

        если не ПутьКХранилищуЛогинПароль.Пусто()
            ПараметрыПроцесса.Добавить(ПутьКХранилищуЛогинПароль)
        ;

    ;

    @Локально
    метод ДополнитьПараметрыПроцессаПутьКЛокальномуХранилищу(ПараметрыПроцесса: Массив<Строка>)

        если не ЛокальныйПуть.Пусто()
            ПараметрыПроцесса.Добавить("-C")
            ПараметрыПроцесса.Добавить(ЛокальныйПуть)
        ;

    ;

    @Локально
    метод ДополнитьПараметрыПроцессаКлючом(ПараметрыПроцесса: Массив<Строка>): Файл

        знч ВременныйФайл = Файлы.СоздатьВременныйФайл("", "", Истина)

        если не Ключ.Пусто()
            ВременныйФайл.ОткрытьПотокЗаписи().Записать(Ключ)
            ПараметрыПроцесса.Добавить("--config")
            ПараметрыПроцесса.Добавить("core.sshCommand=\"ssh -i %{ВременныйФайл.Путь}\"")
        ;

        возврат ВременныйФайл
    ;

    @Локально
    метод ВыполнитьКомандуСОжиданием(ИмяКоманды: Строка, ПараметрыКоманды: Массив<Строка>, Таймаут: Длительность = 0с): Строка
        
        знч ПараметрыСтрокой = Строки.Соединить(ПараметрыКоманды, " ")
        Консоль.Записать("=================================================================")
        Консоль.Записать("\"%ИмяКоманды\" %ПараметрыСтрокой")
        Консоль.Записать("=================================================================")

        пер Процесс = новый ПроцессОс(ИмяКоманды, ПараметрыКоманды)
        Процесс.Запустить()

        пер времяОжидания = 0с
        пер КодВозврата = 0
        
        пока не Процесс.ОжидатьЗавершения(60с) и Процесс.Живой()

            если Таймаут != 0с и Таймаут <= времяОжидания
                пер текстОшибки = "При выполнении команды платформы превышено время ожидания выполнения %Таймаут"
                Процесс.Остановить()
                выбросить новый ИсключениеНедопустимоеСостояние(текстОшибки)
            ;
            времяОжидания += 60с
        ;

        если Процесс.Живой()
            Процесс.Остановить()
        ;

        пер Результат = Процесс.ПолучитьПотокВывода().ПрочитатьКакСтроку()

        Консоль.Записать(Результат)

        КодВозврата = Процесс.ПолучитьКодВозврата()

        если не КодВозврата == 0
            Консоль.Записать("Код возврата: %КодВозврата")
            Консоль.Записать("\н")
            Консоль.Записать(Процесс.ПолучитьПотокОшибок().ПрочитатьКакСтроку())
            выбросить новый ИсключениеНедопустимоеСостояние()
        ;

        возврат Результат
    ;
;